---
import Base from './Base.astro';
import '../styles/plot-grid.css';

interface Props {
  projectName: string;
  subpageName: string;
  defaultGridCols?: number;
  plots: Array<{
    id: string;
    title: string;
    description: string;
    axes?: { x: string; y: string };
    file?: string;
    files?: string[];
    columnHeaders?: Array<{
      afterIndex: number;
      text: string;
    }>;
    gridLayout?: {
      rowHeader: string;
      colHeader: string;
      rows: string[];
      cols: string[];
      files: string[][];
    };
    defaultGridCols?: number;
  }>;
  backLink: string;
}

const { projectName, subpageName, plots, backLink, defaultGridCols = 4 } = Astro.props;
---

<Base title={`${projectName} - ${subpageName}`}>
  <div class="container">
    <header>
      <a href={backLink} class="back-link">← Back to {projectName}</a>
      <h1>{subpageName}</h1>
    </header>

    <div class="plot-grid">
      {plots.map((plot) => {
        const plotGridCols = plot.defaultGridCols ?? defaultGridCols;
        return (
          <button 
            class="plot-card" 
            data-plot-id={plot.id}
            data-plot-file={plot.file}
            data-plot-files={plot.files ? JSON.stringify(plot.files) : undefined}
            data-plot-column-headers={plot.columnHeaders ? JSON.stringify(plot.columnHeaders) : undefined}
            data-plot-grid-layout={plot.gridLayout ? JSON.stringify(plot.gridLayout) : undefined}
            data-plot-title={plot.title}
            data-plot-description={plot.description}
            data-plot-axes={JSON.stringify(plot.axes)}
            data-plot-grid-cols={plotGridCols}
          >
            <div class="plot-card-content">
              <h3>{plot.title}</h3>
              <p class="description">{plot.description}</p>
            </div>
          </button>
        );
      })}
    </div>
  </div>

  <!-- Modal for PDF display -->
  <div id="plot-modal" class="modal" data-default-grid-cols={defaultGridCols}>
    <div class="modal-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h2 id="modal-title"></h2>
        <div class="pdf-grid-controls" id="pdf-grid-controls" style="display: none;">
          <label for="pdf-grid-cols">Columns:</label>
          <select id="pdf-grid-cols">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
            <option value="6">6</option>
          </select>
        </div>
        <button id="modal-close" aria-label="Close modal">×</button>
      </div>
      <div class="modal-body">
        <div id="pdf-grid-container">
          <canvas id="pdf-canvas"></canvas>
        </div>
        <div class="pdf-controls">
          <button id="prev-page">← Previous</button>
          <span id="page-info"></span>
          <button id="next-page">Next →</button>
        </div>
      </div>
    </div>
  </div>

  <script type="module" src="/scripts/plot-grid.js" is:inline></script>
</Base>
