---
import PlotGrid from '../../layouts/PlotGrid.astro';
import project from '../../data/VVsemilep/index.js';
import subpage from '../../data/VVsemilep/MCPol.json';

if (!project || !subpage) throw new Error('Page not found');
---

<PlotGrid
  projectName={project.name}
  subpageName={subpage.name}
  defaultGridCols={subpage.defaultGridCols}
  plots={subpage.plots}
  backLink="/VVsemilep"
/>
