{
    "name": "physics-plots",
    "compatibility_date": "2026-02-04",
    "compatibility_flags": [
        "nodejs_compat",
        "global_fetch_strictly_public"
    ],
    "assets": {
        "directory": "./dist"
    },
    "observability": {
        "enabled": true
    },
    "routes": [
        {
            "pattern": "plots.huanguo.com",
            "custom_domain": true
        }
    ]
}